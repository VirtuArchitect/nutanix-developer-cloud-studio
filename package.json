{
  "name": "nutanix-developer-cloud-studio",
  "private": true,
  "version": "2.95.0-lab-pilot-runbook-workflow",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "api:dev": "tsx server/index.ts",
    "api:start": "tsx server/index.ts",
    "build": "tsc && vite build",
    "build:api": "tsc -p tsconfig.server.json",
    "build:all": "npm run build && npm run build:api",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run --pool=threads --maxWorkers=1",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run build:all && npm run test:e2e",
    "validate:runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/validate-runtime-package.ps1",
    "validate:onprem": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/validate-onprem-config.ps1",
    "validate:backup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/test-state-backup-restore.ps1",
    "validate:container-config": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/validate-container-config-pack.ps1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  }
}
