# Copy to .env.mock-prism for local mock Prism Central lifecycle testing.
# This file contains only disposable mock values. Never use it for a real Prism Central endpoint.

APP_ENV=lab
HOST=0.0.0.0
PORT=8080
NDC_STATIC_DIR=/app/dist
NDC_DATA_FILE=/data/ndc-studio-mock-prism.json
NDC_REPOSITORY=json
NDC_AUDIT_RETENTION_EVENTS=500
NDC_RATE_LIMIT_PER_MINUTE=120

# Local lab identity boundary for a private developer/test VM.
NDC_REQUIRE_TRUSTED_IDENTITY=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
NDC_DEFAULT_ROLE=Platform Admin

# NDC points at the mock Prism Central service in docker-compose.mock-prism.yml.
NUTANIX_PRISM_CENTRAL_URL=http://mock-prism:9440
NUTANIX_PRISM_USERNAME=mock-prism-user
NUTANIX_PRISM_PASSWORD=mock-prism-password
NDC_PRISM_TLS_INSECURE=false

# Explicit opt-in switches for the mock-backed lab lifecycle path.
NDC_AHV_REAL_ADAPTER_ENABLED=true
NDC_CONTROLLED_PROVISIONING_ENABLED=true
NDC_AHV_LAB_LIFECYCLE_ENABLED=true

# Mock fixture UUIDs. These match fixtures/mock-prism/seed.json.
NDC_AHV_ALLOWED_CLUSTER_UUID=mock-cluster-uuid
NDC_AHV_ALLOWED_PROJECT_UUID=mock-project-uuid
NDC_AHV_ALLOWED_SUBNET_UUID=mock-subnet-uuid
NDC_AHV_ALLOWED_IMAGE_UUID=mock-image-uuid
NDC_AHV_VM_NAME_PREFIX=ndc-lab-
NDC_AHV_MAX_CPU=4
NDC_AHV_MAX_MEMORY_GB=16
NDC_AHV_MAX_DISK_GB=160
NDC_AHV_DEFAULT_EXPIRY_HOURS=24

# Evidence reference used by mock lifecycle smoke only.
NDC_AUTHORIZED_PENTEST_SCOPE_REF=mock-prism-authorized-local-scope
NDC_AUTHORIZED_PENTEST_SCOPE_ACTIVE=true

# Mock Prism service settings.
MOCK_PRISM_HOST=0.0.0.0
MOCK_PRISM_PORT=9440
NDC_MOCK_PRISM_FIXTURE=/app/fixtures/mock-prism/seed.json
