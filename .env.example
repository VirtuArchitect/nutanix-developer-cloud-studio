# Copy to .env for local development.
# Never commit real secrets.

APP_ENV=development
LOG_LEVEL=info

# API/runtime settings
HOST=0.0.0.0
PORT=8080
NDC_STATIC_DIR=dist
NDC_DATA_FILE=.data/ndc-studio.json
NDC_REPOSITORY=json
NDC_DATABASE_SCHEMA=ndc_studio
DATABASE_URL=
NDC_AUDIT_RETENTION_EVENTS=500
NDC_AUDIT_EXPORT_DESTINATION_REF=
NDC_RATE_LIMIT_PER_MINUTE=120

# Future on-prem integration settings.
# Keep real values in a vault or environment-specific secret store.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_REDIRECT_URI=http://localhost:8080/auth/callback
NDC_DEFAULT_ROLE=Platform Admin
NDC_REQUIRE_TRUSTED_IDENTITY=false
NUTANIX_PRISM_CENTRAL_URL=
NUTANIX_MOCK_PRISM_CENTRAL_URL=http://localhost:8080/mock-prism
NUTANIX_NCM_URL=
NUTANIX_NKP_URL=
NUTANIX_NDB_URL=
NUTANIX_NUS_URL=
NUTANIX_NAI_URL=
NUTANIX_CREDENTIAL_PROFILE=lab-readonly
NDC_PRISM_REAL_ADAPTER=disabled

# Lab-only AHV lifecycle testing. Keep disabled unless an authorized test cluster is in scope.
NDC_AHV_LAB_PROVIDER=prism-central
NDC_AHV_REAL_ADAPTER_ENABLED=false
NDC_AHV_PE_LAB_ADAPTER_ENABLED=false
NDC_CONTROLLED_PROVISIONING_ENABLED=false
NDC_AHV_LAB_LIFECYCLE_ENABLED=false
NUTANIX_PRISM_USERNAME=
NUTANIX_PRISM_PASSWORD=
NUTANIX_PRISM_ELEMENT_URL=
NUTANIX_PRISM_ELEMENT_USERNAME=
NUTANIX_PRISM_ELEMENT_PASSWORD=
NDC_AHV_ALLOWED_CLUSTER_UUID=
NDC_AHV_ALLOWED_PROJECT_UUID=
NDC_AHV_ALLOWED_SUBNET_UUID=
NDC_AHV_ALLOWED_IMAGE_UUID=
NDC_AHV_PE_ALLOWED_CLUSTER_UUID=
NDC_AHV_PE_ALLOWED_SUBNET_UUID=
NDC_AHV_PE_ALLOWED_IMAGE_UUID=
NDC_AHV_VM_NAME_PREFIX=ndc-lab-
NDC_AHV_MAX_CPU=4
NDC_AHV_MAX_MEMORY_GB=16
NDC_AHV_MAX_DISK_GB=160
NDC_AHV_DEFAULT_EXPIRY_HOURS=24
NDC_PRISM_TLS_INSECURE=false

# Optional frontend API override.
# Leave empty for same-origin /api in on-prem mode or browser mock fallback in static mode.
VITE_API_BASE_URL=
