# Copy to .env.lab on a private lab host. Never commit real values.

APP_ENV=lab
HOST=0.0.0.0
PORT=8080
NDC_STATIC_DIR=/app/dist
NDC_DATA_FILE=/data/ndc-studio.json
NDC_REPOSITORY=json
NDC_AUDIT_RETENTION_EVENTS=500
NDC_RATE_LIMIT_PER_MINUTE=120

# Identity boundary. Prefer true behind a trusted ingress that sets x-ndc-* headers.
NDC_REQUIRE_TRUSTED_IDENTITY=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=

# Prism Central lab target.
NUTANIX_PRISM_CENTRAL_URL=https://prism-central.example.invalid:9440
NUTANIX_PRISM_USERNAME=
NUTANIX_PRISM_PASSWORD=
NDC_PRISM_TLS_INSECURE=false

# Explicit opt-in switches for AHV lab lifecycle.
NDC_AHV_REAL_ADAPTER_ENABLED=false
NDC_CONTROLLED_PROVISIONING_ENABLED=false
NDC_AHV_LAB_LIFECYCLE_ENABLED=false

# Allowed lab scope. Use disposable test objects only.
NDC_AHV_ALLOWED_CLUSTER_UUID=
NDC_AHV_ALLOWED_PROJECT_UUID=
NDC_AHV_ALLOWED_SUBNET_UUID=
NDC_AHV_ALLOWED_IMAGE_UUID=
NDC_AHV_VM_NAME_PREFIX=ndc-lab-
NDC_AHV_MAX_CPU=4
NDC_AHV_MAX_MEMORY_GB=16
NDC_AHV_MAX_DISK_GB=160
NDC_AHV_DEFAULT_EXPIRY_HOURS=24

# Existing evidence gates.
NDC_AUTHORIZED_PENTEST_SCOPE_REF=
NDC_AUTHORIZED_PENTEST_SCOPE_ACTIVE=false
