# NDC Studio on-prem Postgres profile
HOST=0.0.0.0
PORT=8080
NDC_DEPLOYMENT_PROFILE=on-prem-starter
NDC_REPOSITORY=postgres
DATABASE_URL=postgresql://ndc_user@example.invalid:5432/ndc_studio
NDC_DATABASE_SCHEMA=ndc_studio
NDC_REQUIRE_TRUSTED_IDENTITY=true
NDC_AUDIT_RETENTION_EVENTS=5000
NDC_AUDIT_SIGNING_KEY_REF=external-kms-or-vault-key-ref
NDC_PRISM_READONLY_HTTP_ENABLED=false
NDC_PRISM_REAL_ADAPTER=disabled
OIDC_ISSUER_URL=https://idp.example
OIDC_CLIENT_ID=ndc-studio
